@model Book
<h1>Add New Book</h1>

<form asp-controller="Books" asp-action="Create" method="post">
    <div asp-validation-summary="All"></div>
    <div>
        <label asp-for="Title"></label>
        <input asp-for="Title" />
        <span asp-validation-for="Title"></span>
    </div>
    <div>
        <label asp-for="Author"></label>
        <input asp-for="Author" />
        <span asp-validation-for="Author"></span>
    </div>
    <div>
        <label asp-for="Price"></label>
        <input asp-for="Price" />
        <span asp-validation-for="Price"></span>
    </div>
    <div>
        <label asp-for="Genre"></label>
        <select asp-for="Genre" asp-items="Html.GetEnumSelectList<Genre>()"></select>
        <span asp-validation-for="Genre"></span>
    </div>
    <div>
        <button type="submit">Save</button>
    </div>
</form>